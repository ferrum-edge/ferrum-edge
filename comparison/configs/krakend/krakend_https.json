{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Ferrum Benchmark - KrakenD HTTPS",
  "port": 8443,
  "timeout": "5s",
  "cache_ttl": "0s",
  "max_idle_connections": 250,
  "max_idle_connections_per_host": 250,
  "disable_keep_alives": false,
  "dialer_timeout": "1s",
  "read_timeout": "5s",
  "write_timeout": "5s",
  "idle_timeout": "120s",
  "tls": {
    "public_key": "/etc/krakend/tls/server.crt",
    "private_key": "/etc/krakend/tls/server.key"
  },
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["http://BACKEND_HOST:3001"],
          "url_pattern": "/health",
          "encoding": "no-op"
        }
      ]
    },
    {
      "endpoint": "/api/echo",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["http://BACKEND_HOST:3001"],
          "url_pattern": "/api/echo",
          "encoding": "no-op"
        }
      ]
    }
  ]
}
