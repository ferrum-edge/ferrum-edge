{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Ferrum Benchmark - KrakenD HTTP/2 TLS",
  "port": 8443,
  "timeout": "30s",
  "cache_ttl": "0s",
  "max_idle_connections": 500,
  "max_idle_connections_per_host": 500,
  "disable_keep_alives": false,
  "dialer_timeout": "5s",
  "read_timeout": "30s",
  "write_timeout": "30s",
  "idle_timeout": "120s",
  "tls": {
    "public_key": "CERT_PATH",
    "private_key": "KEY_PATH",
    "enable_mtls": false
  },
  "client_tls": {
    "allow_insecure_connections": true
  },
  "endpoints": [
    {
      "endpoint": "/echo",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["https://127.0.0.1:3443"],
          "url_pattern": "/echo",
          "encoding": "no-op",
          "disable_host_sanitize": true
        }
      ]
    },
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "host": ["http://127.0.0.1:3010"],
          "url_pattern": "/health",
          "encoding": "no-op"
        }
      ]
    }
  ]
}
