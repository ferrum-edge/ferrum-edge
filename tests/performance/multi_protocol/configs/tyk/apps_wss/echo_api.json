{
  "name": "Echo API (WSS E2E TLS)",
  "slug": "echo-wss",
  "api_id": "echo-wss",
  "org_id": "default",
  "use_keyless": true,
  "active": true,
  "enable_websockets": true,
  "proxy": {
    "listen_path": "/ws",
    "target_url": "https://127.0.0.1:3446/",
    "strip_listen_path": true,
    "transport": {
      "ssl_insecure_skip_verify": true
    }
  },
  "version_data": {
    "not_versioned": true,
    "default_version": "Default",
    "versions": { "Default": { "name": "Default" } }
  }
}
