{
  "name": "Echo TCP (E2E TLS)",
  "slug": "echo-tcp-tls",
  "api_id": "echo-tcp-tls",
  "org_id": "default",
  "use_keyless": true,
  "active": true,
  "protocol": "tls",
  "listen_port": 5001,
  "certificates": ["*"],
  "proxy": {
    "target_url": "tls://127.0.0.1:3444",
    "listen_path": "/",
    "transport": {
      "ssl_insecure_skip_verify": true
    }
  },
  "version_data": {
    "not_versioned": true,
    "default_version": "Default",
    "versions": { "Default": { "name": "Default" } }
  }
}
